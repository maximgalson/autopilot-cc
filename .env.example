# Autopilot environment variables
# Copy to ~/.claude/autopilot/.env and fill in.
# All variables are optional — autopilot degrades gracefully if any are missing.

# --- LightRAG (knowledge graph) ---
# Skip these if you don't run LightRAG locally.
# LIGHTRAG_URL=http://localhost:9621
# LIGHTRAG_USER=admin
# LIGHTRAG_PASS=

# --- Notion sync (tasks → Notion DB, two-way) ---
# Required if config.notion_sync.enabled = true.
# Token: https://www.notion.so/my-integrations
# DB ID: open the database as full page → URL contains 32-char hex; that's the ID.
# NOTION_TOKEN=
# NOTION_DB_ID=

# --- Wiki location (where session digests are written) ---
# Default: ~/claudecode/wiki if it exists, else ~/.claude/autopilot/wiki.
# WIKI_DIR=
